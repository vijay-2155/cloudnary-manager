# ─────────────────────────────────────────────────────────────────────────────
# Cloudinary Manager — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your Cloudinary credentials.
#
#   cp .env.example .env.local
#
# Get your credentials from: https://console.cloudinary.com/
# ─────────────────────────────────────────────────────────────────────────────

# Your Cloudinary cloud name (visible on the dashboard)
# Example: dqdejwtwd
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# Your Cloudinary API Key (treat like a username)
# Example: 123456789012345
CLOUDINARY_API_KEY=your_api_key

# Your Cloudinary API Secret (treat like a password — never expose publicly)
# Example: abcdefghijklmnopqrstuvwxyz12345
CLOUDINARY_API_SECRET=your_api_secret

# ─────────────────────────────────────────────────────────────────────────────
# Auth (password gate)
# ─────────────────────────────────────────────────────────────────────────────

# The password required to access the app
AUTH_PASSWORD=your_strong_password

# A long random secret used as the session token value
# Generate with: openssl rand -hex 32
AUTH_SECRET=generate_with_openssl_rand_hex_32
